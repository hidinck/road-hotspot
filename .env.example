# ── TrafficSense Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit secrets.

# ── Database URL ───────────────────────────────────────────────────────────────
# SQLite (local dev — no setup needed):
DATABASE_URL=sqlite:///./hotspot.db

# Neon PostgreSQL (Vercel production — get this string from neon.tech dashboard):
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Render PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Dataset size ───────────────────────────────────────────────────────────────
# Vercel sets VERCEL=1 automatically (auto-selects 30 vehicles).
# Override manually here only if needed:
# N_VEHICLES=30

# ── App port (local only) ──────────────────────────────────────────────────────
# PORT=8000
